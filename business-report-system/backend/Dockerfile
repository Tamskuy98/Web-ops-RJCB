##################################################
# BASE IMAGE
# Menggunakan Node.js versi 20
##################################################

FROM node:20-alpine



##################################################
# Folder kerja dalam container
##################################################

WORKDIR /app



##################################################
# Copy package terlebih dahulu
# supaya cache Docker lebih efektif
##################################################

COPY package*.json ./



##################################################
# Install dependency Express
##################################################

RUN npm install



##################################################
# Copy source code backend
##################################################

COPY . .



##################################################
# Port aplikasi Express
##################################################

EXPOSE 5000


##################################################
# Jalankan Prisma
##################################################

RUN npx prisma generate

##################################################
# Jalankan Express
##################################################

CMD ["npm","start"]